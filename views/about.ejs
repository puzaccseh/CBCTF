<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head', {title}) %></head>
<body>

<%- include('partials/nav', {active}) %>

<section class="page-hero">
    <div class="container">
        <div class="section-badge">Our Story</div>
        <h1 class="page-hero-title">About Cyber Bangla</h1>
        <p class="page-hero-sub">A decade of defending Bangladesh's digital borders.</p>
    </div>
</section>

<!-- Company Story -->
<section class="section">
    <div class="container">
        <div class="about-grid">
            <div class="about-text">
                <h2 class="section-title">Who We Are</h2>
                <p>Founded in 2015 by a group of BUET-trained security engineers, Cyber Bangla has grown from a four-person consultancy to Bangladesh's largest dedicated cybersecurity firm with over 50 certified professionals.</p>
                <p>We have conducted thousands of penetration tests across banking, telecom, healthcare, and government sectors – discovering and responsibly disclosing critical vulnerabilities that, if left unaddressed, could have compromised millions of Bangladeshi citizens.</p>
                <p>Our research team actively contributes to open-source security tooling and regularly publishes threat intelligence reports on the evolving South Asian threat landscape.</p>
                <div class="about-certs">
                    <span class="cert-badge">OSCP</span>
                    <span class="cert-badge">CEH</span>
                    <span class="cert-badge">CISSP</span>
                    <span class="cert-badge">ISO 27001</span>
                    <span class="cert-badge">CREST</span>
                    <span class="cert-badge">GPEN</span>
                </div>
            </div>
            <div class="about-visual">
                <div class="hex-grid">
                    <div class="hex-item"><span>&#128272;</span><p>700+ Pentest Reports</p></div>
                    <div class="hex-item"><span>&#9888;</span><p>4,200+ Vulnerabilities Found</p></div>
                    <div class="hex-item"><span>&#128203;</span><p>50+ Certified Experts</p></div>
                    <div class="hex-item"><span>&#9989;</span><p>99% Client Retention</p></div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Mission & Vision -->
<section class="section section-alt">
    <div class="container">
        <div class="mv-grid">
            <div class="mv-card">
                <div class="mv-icon">&#127919;</div>
                <h3>Our Mission</h3>
                <p>To make Bangladesh's digital infrastructure resilient against all classes of cyber threat, from script kiddies to nation-state actors, through offensive security expertise and knowledge transfer.</p>
            </div>
            <div class="mv-card">
                <div class="mv-icon">&#128301;</div>
                <h3>Our Vision</h3>
                <p>A Bangladesh where every organisation — regardless of size — has access to world-class cybersecurity expertise and the skills to defend itself in an increasingly hostile digital world.</p>
            </div>
            <div class="mv-card">
                <div class="mv-icon">&#9878;</div>
                <h3>Our Values</h3>
                <p>Integrity, transparency, and responsible disclosure. We believe in fixing problems, not just finding them. Every engagement concludes with actionable remediation guidance.</p>
            </div>
        </div>
    </div>
</section>

<!-- Team -->
<section class="section">
    <div class="container">
        <div class="section-header">
            <div class="section-badge">Leadership</div>
            <h2 class="section-title">Meet the Team</h2>
            <p class="section-sub">World-class security researchers and engineers driving the mission forward.</p>
        </div>
        <div class="team-grid">
            <div class="team-card">
                <div class="team-avatar">&#128100;</div>
                <h4>Rafiqul Islam</h4>
                <span class="team-role">CEO & Lead Penetration Tester</span>
                <p>OSCP, CEH, CISSP. Former CIRT lead at BTRC. 14 years in offensive security.</p>
            </div>
            <div class="team-card">
                <div class="team-avatar">&#128100;</div>
                <h4>Nasrin Akhter</h4>
                <span class="team-role">Head of Red Team Operations</span>
                <p>GPEN, GWAPT. Specialist in APT simulation and Social Engineering. Speaker at DEFCON.</p>
            </div>
            <div class="team-card">
                <div class="team-avatar">&#128100;</div>
                <h4>Tanvir Hassan</h4>
                <span class="team-role">Chief Security Architect</span>
                <p>CISSP, CISM. Cloud and zero-trust architecture. Previously at IBM Security, Singapore.</p>
            </div>
            <div class="team-card">
                <div class="team-avatar">&#128100;</div>
                <h4>Fatema Begum</h4>
                <span class="team-role">Malware Analyst & Threat Intel</span>
                <p>Reverse engineering, IOC research, and YARA rule development. CVE author ×12.</p>
            </div>
        </div>
    </div>
</section>

<section class="cta-section">
    <div class="container">
        <div class="cta-content">
            <h2>Want to Join Our Team?</h2>
            <p>We are always looking for talented security researchers and engineers.</p>
            <a href="/contact" class="btn btn-primary btn-lg">View Open Positions</a>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
